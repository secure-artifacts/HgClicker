{
    "manifest_version": 2,
    "name": "HeyGen Helper T2 / Auto Click",
    "version": "2.3.8",
    "author": "James",
    "description": "HeyGen 辅助工具 自动点击",

    "icons": {
        "16": "icon16.png",
        "32": "icon32.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "browser_action": {
        "default_icon": {
            "16": "icon16.png",
            "32": "icon32.png",
            "48": "icon48.png",
            "128": "icon128.png"
        },
        "default_title": "HeyGen Helper"
    },

    "permissions": [
        "tabs",
        "activeTab",
        "storage",
        "downloads",
        "browsingData",
        "cookies",
        "webRequest",
        "<all_urls>"
    ],

    "content_scripts": [
        {
            "matches": [
                "https://app.heygen.com/*"
            ],
            "js": [
                "js/myUtil.js",
                "js/myXPath.js",
                "js/mySimulate.js",
                "js/myElementA.js",
                "js/proc01Questionnaire.js",
                "js/proc02UpdateImage.js",
                "js/proc03Walkthrough.js",
                "js/proc04Caption.js",
                "js/proc05AvatarForm.js",
                "js/proc06OutPutName.js",
                "js/proc07Popover.js",
                "js/proc08BatchDownload.js",
                "js/proc09AutoRedirect.js",
                "js/proc10AvatarClick.js",
                "content.js"
            ],
            "css": [
                "css/styleA.css",
                "css/bootstrap.min.css"
            ],
            "run_at": "document_end"
        }
    ],

    "web_accessible_resources": [
        "js/*.js",
        "css/*",
        "icon16.png",
        "icon32.png",
        "icon48.png",
        "icon128.png"
    ],

    "commands": {
        "generate-video": {
            "suggested_key": {
                "default": "Ctrl+B",
                "mac": "Command+B"
            },
            "description": "Generate video"
        }
    },

    "background": {
        "scripts": ["background.js"]
    },

    "content_security_policy": "script-src 'self'; object-src 'self'",

    "browser_specific_settings": {
        "gecko": {
            "id": "heygen-helper@james",
            "strict_min_version": "57.0"
        }
    }
}
