{
    "manifest_version": 3,
    "name": "HeyGen Helper T1 / Auto Click",
    "version": "1.3.2",
    "author": "James",
    "description": "HeyGen 辅助工具 自动点击",
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    },
    "permissions": [
        "tabs",
        "activeTab",
        "scripting",
        "storage"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://app.heygen.com/*"
            ],
            "js": [
                "js/myUtil.js",
                "js/myLibrary.js",
                "js/myJson.js",
                "js/myXPath.js",
                "js/myFacebook.js",
                "js/mySimulate.js",
                "js/myElementA.js",
                "js/myEffect.js",
                "js/myStorage.js",
                "js/myExtra.js",
                "js/proc01Questionnaire.js",
                "js/proc02UpdateImage.js",
                "js/proc03Walkthrough.js",
                "js/proc04Caption.js",
                "js/proc05AvatarForm.js",
                "js/proc06OutPutName.js",
                "js/proc07Popover.js",
                "content.js"
            ],
            "css": [
                "css/styleA.css",
                "css/bootstrap.min.css"
            ],
            "run_at": "document_end"
        }
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "web_accessible_resources": [
        {
            "matches": [
                "<all_urls>"
            ],
            "resources": [
                "js/*.js",
                "css/*",
                "icon.png"
            ]
        }
    ],
    "commands": {
        "generate-video": {
            "suggested_key": {
                "default": "Ctrl+B",
                "mac": "Command+B"
            },
            "description": "Generate video"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self' "
    }
}